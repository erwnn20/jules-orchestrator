{
  "compilerOptions": {
    "target": "ESNext",
    "module": "CommonJS",
    "lib": [
      "ESNext",
      "DOM"
    ],
    "strict": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "outDir": "dist",
    "rootDir": "src",
    "skipLibCheck": true,
    "paths": {
      "@config/*": [
        "./src/renderer/config/*"
      ],
      "@context/*": [
        "./src/renderer/context/*"
      ],
      "@data/*": [
        "./src/renderer/data/*"
      ],
      "@pages/*": [
        "./src/renderer/components/pages/*"
      ],
      "@components/*": [
        "./src/renderer/components/*"
      ],
      "@interfaces/*": [
        "./src/renderer/interfaces/*"
      ],
      "@/*": [
        "./src/renderer/*"
      ]
    }
  },
  "include": [
    "src"
  ]
}