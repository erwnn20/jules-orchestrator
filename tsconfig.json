{
  "compilerOptions": {
    "target": "ESNext",
    "module": "CommonJS",
    "lib": ["ESNext", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "outDir": "dist",
    "rootDir": "src",
    "skipLibCheck": true,
    "paths": {
      "@pages/*": ["./src/renderer/components/pages/*"],
      "@components/*": ["./src/renderer/components/*"],
      "@interfaces/*": ["./src/renderer/interfaces/*"]
    }
  },
  "include": ["src"],
}