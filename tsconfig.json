{
  "compilerOptions": {
    "target": "ESNext",
    "module": "CommonJS",
    "lib": ["ESNext", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "outDir": "dist",
    "rootDir": "src",
    "skipLibCheck": true,
    "paths": {
      "@shared/*": [
        "./src/shared/*"
      ],
      "@jules/*": [
        "./src/shared/jules/*"
      ],
      "@github/*": [
        "./src/shared/github/*"
      ],
      "@context/*": [
        "./src/renderer/context/*"
      ],
      "@services/*": [
        "./src/renderer/services/*"
      ],
      "@pages/*": [
        "./src/renderer/components/pages/*"
      ],
      "@components/*": [
        "./src/renderer/components/*"
      ],
      "@renderer/*": [
        "./src/renderer/*"
      ],
      "@electron/*": [
        "./src/electron/*"
      ]
    }
  },
  "include": ["src"]
}